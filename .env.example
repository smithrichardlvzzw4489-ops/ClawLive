# Database
DATABASE_URL="postgresql://clawlive:password@localhost:5432/clawlive"
POSTGRES_USER=clawlive
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=clawlive

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key"
JWT_EXPIRES_IN="24h"

# Telegram OAuth (optional)
TELEGRAM_BOT_TOKEN="your_telegram_bot_token"
TELEGRAM_BOT_USERNAME="your_bot_username"

# Server
SERVER_PORT=3001
NODE_ENV=development

# Frontend URLs (for Next.js)
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"
# Vercel 部署 web 时：NEXT_PUBLIC_API_URL / VIBEKIDS_PROXY_ORIGIN 必须为公网 https（勿用 localhost），
# 否则 rewrites 会触发 DNS_HOSTNAME_RESOLVED_PRIVATE。本地 dev 仍可用 localhost。
# NEXT_PUBLIC_API_URL="https://api.your-domain.com"
# VibeKids 子应用（apps/vibekids，basePath=/vibekids）：web 开发时反向代理到此 origin
# 默认 http://localhost:3002；生产部署独立子应用时改为其公网 origin
# VIBEKIDS_PROXY_ORIGIN="http://localhost:3002"
# 是否展示直播相关入口与页面（不设或 false = 隐藏；true = 显示）
# NEXT_PUBLIC_SHOW_LIVE_FEATURES=true

# OpenClaw Integration
WEBHOOK_SECRET="your-webhook-secret-for-verification"

# GitHub API：Darwin 进化器与 search_github_skills 检索 SKILL.md；不设则匿名易限流
# GITHUB_TOKEN="ghp_xxxx"  # 或 GH_TOKEN

# Darwin 全网能力（可选）
# TAVILY_API_KEY=        # web_search
# JINA_API_KEY=          # url_read（Jina Reader，不设也可用免费档）
# EXA_API_KEY=           # exa_search 语义搜索（与 Agent Reach / Exa 对齐）
# AUTOCLI_API_BASE=https://www.autocli.ai   # Darwin autocli stats（默认官方；自建兼容端可改）
# OPENCLI_RS_BIN=/usr/local/bin/opencli-rs  # 服务端执行 opencli-rs（autocli action=run）；不设则仅 stats/help

# LLM：若已配置下方 LiteLLM，则站内摘要等优先走代理；否则回退 OpenRouter
# OPENROUTER_API_KEY="sk-or-xxxx"
# OPENROUTER_MODEL="anthropic/claude-opus-4.6"

# 虾米积分 → LiteLLM 代理（虚拟 Key + 预算）；未配置时兑换与连接测试不可用
# LITELLM_BASE_URL="http://localhost:4000"
# LITELLM_MASTER_KEY="sk-..."
# 展示给前端的代理根地址（可与 BASE 相同，或公网域名）
# LITELLM_PUBLIC_BASE_URL="https://llm.example.com"
# POINTS_PER_USD=1000
# MIN_REDEEM_POINTS=100
# LITELLM_MODELS="gpt-4o,gpt-4o-mini"
# 服务端生成作品摘要等使用的模型（可选，默认取 LITELLM_MODELS 第一个）
# LLM_SUMMARY_MODEL="gpt-4o-mini"

# Upload (optional, for screenshots)
UPLOAD_MAX_SIZE=10485760
CDN_URL=""
