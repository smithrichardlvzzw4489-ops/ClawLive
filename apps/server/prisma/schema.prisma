generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @default(uuid())
  telegramId        String?  @unique
  /// LinkedIn OpenID Connect subject (`sub` from userinfo)
  linkedInId        String?  @unique
  /// GitHub OAuth user id
  githubId          String?  @unique
  /// GitHub login name (e.g. "octocat")
  githubUsername    String?
  /// AES-256-GCM encrypted GitHub access token for API crawling
  githubAccessToken String?  @db.Text
  /// Raw crawled GitHub data (repos, languages, commits)
  githubProfileJson Json?
  /// 多平台爬取快照（SO/npm/HF 等），供站内画像卡片与联系方式展示
  codernetMultiPlatform Json?
  /// LLM-generated Codernet analysis (tags, commentary, quadrant)
  codernetAnalysis  Json?
  /// 用户自行填写的「个人简历」正文；与 codernetAnalysis 技术画像独立，合成为对外完整叙事
  personalResume    String?  @db.Text
  /// Last time GitHub profile was crawled
  codernetCrawledAt DateTime?
  /// GITLINK 三入口：POST /api/codernet/crawl（我的画像）
  codernetMinePortraitCalls   Int @default(0)
  /// POST /api/codernet/github/:user 已登录扣 profile_lookup（GitHub 画像）
  codernetGithubPortraitCalls Int @default(0)
  /// POST /api/codernet/search 已登录扣 search（LINK）
  codernetLinkSearchCalls     Int @default(0)
  /// GITLINK GitHub 画像页：复制页面链接（已登录 POST /api/codernet/portrait-share）
  codernetPortraitShareCopyCalls   Int @default(0)
  /// 下载分享长图 PNG
  codernetPortraitShareDownloadCalls Int @default(0)
  /// 系统原生分享（Web Share API）
  codernetPortraitShareNativeCalls   Int @default(0)
  /// 微信小程序 openid，与站内账号绑定后用于 wx.login 换票
  wechatMpOpenid    String?  @unique
  username          String   @unique
  email             String?  @unique
  passwordHash      String?
  avatarUrl         String?
  bio               String?  @db.Text
  openClawApiKey    String?
  /// 虾米积分（可兑换 LiteLLM 代理额度等）
  clawPoints        Int      @default(0)
  /// LiteLLM 虚拟 Key；勿写入日志或下发给前端（除专用接口）
  litellmVirtualKey String?
  /// 首次申请 Darwin 时填写的问卷（JSON），申请成功时写入
  darwinOnboarding  Json?
  /// Codernet：是否对招聘方展示「开放机会」（站内依据，与 githubUsername 绑定展示）
  openToOpportunities Boolean @default(false)
  openToOpportunitiesUpdatedAt DateTime?
  /// 用户自行填写的对外求职链接 [{ label, url, addedAt? }]，如 Wellfound、个人页等
  jobSeekingExternalProfiles Json?
  /// 最近一次 GitHub 爬取时自动检测到的求职文案依据（JSON 数组 JobSeekingSignal）
  jobSeekingDetectedSignals Json?
  /// 站内管理员：可访问用户与使用情况看板（JWT 鉴权 + 服务端校验）
  isAdmin           Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  rooms           Room[]
  comments        Comment[]
  pointLedger     PointLedger[]
  publishedSkills PublishedSkill[]
  evolverRounds   EvolverRound[]

  /// Darwin / Lobster：与本地 JSON 脱钩，统一存 PostgreSQL（Railway）
  lobsterInstance     LobsterInstanceRow?
  lobsterConversation LobsterConversationRow?
  /// VibeKids 创作室经 Darwin 生成时的近期线索（与 Lobster 对话正文分离）
  vibekidsDarwinMemory  VibekidsDarwinMemory?
  installedUserSkills UserInstalledSkill[]
  evolutionPointsAuthored EvolutionPoint[] @relation("EvolutionPointAuthor")
  feedPosts             FeedPost[]

  jobA2ASeekerProfile   JobA2ASeekerProfile?
  jobA2AEmployerProfile JobA2AEmployerProfile?
  jobMatchesAsSeeker    JobA2AMatch[]         @relation("JobMatchSeeker")
  jobMatchesAsEmployer  JobA2AMatch[]         @relation("JobMatchEmployer")
  vibekidsWorks         VibekidsWork[]

  jobPostingsAuthored           JobPosting[]               @relation("JobPostingAuthor")
  jobPostingNotificationsRecv JobPostingNotification[]   @relation("JobPostingNotifyRecipient")
  siteMessagesSent            SiteMessage[]              @relation("SiteMessageSender")
  siteMessagesReceived        SiteMessage[]              @relation("SiteMessageRecipient")

  @@index([username])
  @@index([telegramId])
  @@map("users")
}

/// DarwinClaw 实例（原 lobster-instances.json）
model LobsterInstanceRow {
  userId                       String   @id
  name                         String?
  appliedAt                    DateTime
  lastActiveAt                 DateTime
  messageCount                 Int      @default(0)
  darwinDailyChatDate          String?
  darwinDailyUserMessagesToday Int?
  personalApiKey               String?  @db.Text
  personalApiBaseUrl           String?
  pendingSkillSuggestion       String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Darwin 对话（原 lobster-conversations.json）
model LobsterConversationRow {
  userId         String   @id
  messages       Json
  /// Auto-Compact：{ summary: string, coveredCount: number }
  contextCompact Json?
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// VibeKids：Darwin 路径下的创作交互摘要（用于后续生成时注入上下文）
model VibekidsDarwinMemory {
  userId    String   @id
  entries   Json     @default("[]")
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("vibekids_darwin_memory")
}

/// 用户安装的 Skill（原 lobster-user-skills/.../skills.json）
model UserInstalledSkill {
  id              String   @id @default(uuid())
  userId          String
  skillId         String
  title           String
  description     String   @db.Text
  skillMarkdown   String   @db.Text
  source          String
  installedAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
  @@index([userId])
  @@map("user_installed_skills")
}

/// 进化点（原 evolution-points.json）
model EvolutionPoint {
  id              String   @id
  title           String
  goal            String   @db.Text
  problems        Json
  authorUserId    String
  authorAgentName String
  status          String
  endReason       String?
  createdAt       DateTime
  updatedAt       DateTime
  startedAt       DateTime?
  lastActivityAt  DateTime
  source          String?
  /// 进化点关联的技能包（Markdown），用于验收测试与闭环后安装到 Darwin
  linkedSkills    Json?
  /// 验收状态与用例、最近一次运行结果
  acceptanceJson  Json?

  comments EvolutionComment[]
  author   User     @relation("EvolutionPointAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)

  @@index([authorUserId])
  @@index([status])
  @@map("evolution_points")
}

model EvolutionComment {
  id              String   @id @default(uuid())
  pointId         String
  authorUserId    String
  authorAgentName String
  body            String   @db.Text
  createdAt       DateTime

  point EvolutionPoint @relation(fields: [pointId], references: [id], onDelete: Cascade)

  @@index([pointId])
  @@map("evolution_comments")
}

/// 实验室 Feed（原 feed-posts.json）
model FeedPost {
  id               String    @id @default(uuid())
  authorId         String
  kind             String?
  title            String
  content          String    @db.Text
  imageUrls        Json
  viewCount        Int       @default(0)
  likeCount        Int       @default(0)
  favoriteCount    Int       @default(0)
  commentCount     Int       @default(0)
  createdAt        DateTime
  updatedAt        DateTime?
  publishedByAgent Boolean   @default(false)
  excerpt          String?   @db.Text
  evolutionPointId String?

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([createdAt])
  @@map("feed_posts")
}

model FeedPostComment {
  id        String   @id @default(uuid())
  postId    String
  authorId  String
  content   String   @db.Text
  createdAt DateTime @default(now())

  @@index([postId])
  @@map("feed_post_comments")
}

/// kind: like | favorite
model FeedPostReaction {
  postId String
  userId String
  kind   String

  @@id([postId, userId, kind])
  @@map("feed_post_reactions")
}

/// Darwin 进化器：每轮自动评估、匹配进化网络、GitHub 技能检索等（看板数据源）
model EvolverRound {
  id              String    @id @default(uuid())
  userId          String
  status          String    @default("running") // running | completed | failed
  roundNo         Int
  summary         String?   @db.Text
  assessmentJson Json?
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  error           String?   @db.Text

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  events EvolverEvent[]

  @@index([userId, startedAt(sort: Desc)])
  @@map("evolver_rounds")
}

model EvolverEvent {
  id        String   @id @default(uuid())
  roundId   String
  kind      String
  title     String
  detail    String?  @db.Text
  payload   Json?
  createdAt DateTime @default(now())

  round EvolverRound @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@index([roundId, createdAt])
  @@map("evolver_events")
}

model PointLedger {
  id              String   @id @default(uuid())
  userId          String
  /// 正数为发放，负数为扣减
  delta           Int
  balanceAfter    Int
  reason          String
  metadata        Json?
  idempotencyKey  String?  @unique
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("point_ledger")
}

/// 用户发布的付费社区技能
model PublishedSkill {
  id                String   @id @default(uuid())
  authorId          String
  title             String
  description       String?  @db.Text
  skillMarkdown     String   @db.Text
  tags              String[]
  /// 每次被调用时向调用方扣除的积分（0 = 免费）
  creditCostPerCall Int      @default(0)
  /// 平台抽成比例 0-1，默认 0.2（20%）
  platformFeeRate   Float    @default(0.2)
  installCount      Int      @default(0)
  /// pending / approved / rejected
  status            String   @default("pending")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([status, createdAt])
  @@map("published_skills")
}

model Room {
  id              String    @id
  hostId          String
  title           String
  description     String?   @db.Text
  lobsterName     String
  isLive          Boolean   @default(false)
  privacyFilters  String[]  @default([])
  dashboardUrl    String?
  viewerCount     Int       @default(0)
  createdAt       DateTime  @default(now())
  startedAt       DateTime?
  endedAt         DateTime?
  
  host            User      @relation(fields: [hostId], references: [id], onDelete: Cascade)
  messages        Message[]
  comments        Comment[]
  agentLogs       AgentLog[]
  screenshots     Screenshot[]

  @@index([hostId])
  @@index([isLive])
  @@index([createdAt])
  @@map("rooms")
}

enum MessageSender {
  user
  agent
  system
}

model Message {
  id          String        @id @default(uuid())
  roomId      String
  sender      MessageSender
  content     String        @db.Text
  metadata    Json?
  timestamp   DateTime      @default(now())
  
  room        Room          @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, timestamp])
  @@map("messages")
}

model Comment {
  id          String    @id @default(uuid())
  roomId      String
  userId      String?
  nickname    String
  content     String    @db.Text
  timestamp   DateTime  @default(now())
  
  room        Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([roomId, timestamp])
  @@map("comments")
}

enum AgentLogStatus {
  pending
  success
  error
}

model AgentLog {
  id          String          @id @default(uuid())
  roomId      String
  action      String
  status      AgentLogStatus  @default(pending)
  details     Json?
  timestamp   DateTime        @default(now())
  
  room        Room            @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, timestamp])
  @@map("agent_logs")
}

model Screenshot {
  id          String    @id @default(uuid())
  roomId      String
  imageUrl    String    @db.Text
  caption     String?
  timestamp   DateTime  @default(now())
  
  room        Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, timestamp])
  @@map("screenshots")
}

/// A2A 求职实验：求职者画像（Darwin 建档后同步）
model JobA2ASeekerProfile {
  userId    String   @id
  active    Boolean  @default(true)
  title     String
  city      String?
  salaryMin Int?
  salaryMax Int?
  skills    Json
  narrative String   @db.Text
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("job_a2a_seeker_profiles")
}

/// 招聘方画像
model JobA2AEmployerProfile {
  userId      String   @id
  active      Boolean  @default(true)
  jobTitle    String
  city        String?
  salaryMin   Int?
  salaryMax   Int?
  skills      Json
  companyName String?
  narrative   String   @db.Text
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("job_a2a_employer_profiles")
}

/// 匹配对：Agent 代聊 → 解锁真人
model JobA2AMatch {
  id               String   @id @default(uuid())
  seekerUserId     String
  employerUserId   String
  score            Float
  /// pending_agent | agent_chat | ready_human | human_active | closed
  status           String   @default("pending_agent")
  agentExchangeRounds Int   @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  seeker   User @relation("JobMatchSeeker", fields: [seekerUserId], references: [id], onDelete: Cascade)
  employer User @relation("JobMatchEmployer", fields: [employerUserId], references: [id], onDelete: Cascade)

  agentMessages JobA2AAgentMessage[]
  humanMessages JobA2AHumanMessage[]
  timeline      JobA2AEvent[]

  @@unique([seekerUserId, employerUserId])
  @@index([seekerUserId])
  @@index([employerUserId])
  @@index([status])
  @@map("job_a2a_matches")
}

model JobA2AAgentMessage {
  id        String   @id @default(uuid())
  matchId   String
  /// seeker_agent | employer_agent
  side      String
  body      String   @db.Text
  createdAt DateTime @default(now())

  match JobA2AMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId, createdAt])
  @@map("job_a2a_agent_messages")
}

model JobA2AHumanMessage {
  id           String   @id @default(uuid())
  matchId      String
  authorUserId String
  body         String   @db.Text
  createdAt    DateTime @default(now())

  match JobA2AMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId, createdAt])
  @@map("job_a2a_human_messages")
}

/// 监控时间线（建档、匹配、Agent 轮次、解锁等）
model JobA2AEvent {
  id        String   @id @default(uuid())
  matchId   String?
  userId    String?
  kind      String
  detail    String?  @db.Text
  payload   Json?
  createdAt DateTime @default(now())

  match JobA2AMatch? @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([matchId])
  @@map("job_a2a_events")
}

/// VibeKids 单页作品（持久化在 PostgreSQL；Next /api/vibekids/works 可反代到此）
model VibekidsWork {
  id        String   @id @default(uuid())
  userId    String
  title     String
  html      String   @db.Text
  ageBand   String   @default("unified")
  prompt    String?  @db.Text
  kind      String?
  published Boolean  @default(false)
  likes     Int      @default(0)
  shares    Int      @default(0)
  favorites Int      @default(0)
  comments  Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user              User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  favoriteDedupRows VibekidsWorkFavoriteDedupe[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([published, createdAt(sort: Desc)])
  @@map("vibekids_works")
}

/// 收藏去重：同一 clientId 对同一作品只计一次 favorites 增量
model VibekidsWorkFavoriteDedupe {
  id        String   @id @default(uuid())
  clientId  String
  workId    String
  createdAt DateTime @default(now())

  work VibekidsWork @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@unique([clientId, workId])
  @@index([workId])
  @@map("vibekids_work_favorite_dedupe")
}

/// 职位（公开 JD）：HR 发布的 JD
model JobPosting {
  id          String    @id @default(uuid())
  authorId    String
  title       String
  companyName String?
  location    String?
  body        String    @db.Text
  /// 用于与候选人画像标签匹配的短语，如 ["Rust","后端","上海"]
  matchTags   Json      @default("[]")
  status      String    @default("draft")
  publishedAt DateTime?
  /// 首次「按 JD 智能推荐」完成时间；之后每日从 backlog 向待查看池补充
  firstRecommendAt DateTime?
  /// 最近一次每日任务写入 pending 或执行补缺搜索的时间
  lastDailyRecommendAt DateTime?
  /// 异步首轮推荐进行中（避免与手动点击并发重复扣点）
  recommendBootstrapStartedAt DateTime?
  /// 新建 JD 后首轮异步引导：分步追踪（{ at, phase, ok, detail?, meta? }[]），供排障与前端展示
  recommendBootstrapTrace Json @default("[]")
  /// 待查看推荐（JSON 数组，与推荐 API 单条结构一致）
  pendingRecommendHits Json @default("[]")
  /// 已检索尚未进入待查看池的候选人（结构同 pendingRecommendHits）
  recommendBacklogHits Json @default("[]")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  author         User                       @relation("JobPostingAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  notifyReceipts JobPostingNotification[]
  candidates     JobPostingCandidate[]

  @@index([status, publishedAt(sort: Desc)])
  @@index([authorId])
  @@map("job_postings")
}

/// 某 JD 已向该用户记过一次匹配推送（去重，避免重复编辑重复轰炸）
model JobPostingNotification {
  id           String   @id @default(uuid())
  jobPostingId String
  recipientId  String
  createdAt    DateTime @default(now())

  jobPosting JobPosting @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  recipient  User       @relation("JobPostingNotifyRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@unique([jobPostingId, recipientId])
  @@index([recipientId])
  @@map("job_posting_notifications")
}

/// 招聘管理：某 JD 下的候选人及流程状态
model JobPostingCandidate {
  id             String   @id @default(uuid())
  jobPostingId   String
  githubUsername String
  displayName    String?
  email          String?
  notes          String?  @db.Text
  /// 新建 | 沟通中 | 面试中 | 已发Offer | 已入职 | 已拒绝 | 暂不联系
  pipelineStage  String   @default("新建")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  jobPosting JobPosting @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)

  @@unique([jobPostingId, githubUsername])
  @@index([jobPostingId])
  @@map("job_posting_candidates")
}

/// 用户间站内信（与 /api/inbox Agent 通道无关）
model SiteMessage {
  id          String    @id @default(uuid())
  senderId    String
  recipientId String
  subject     String    @default("") @db.VarChar(300)
  body        String    @db.Text
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  sender    User @relation("SiteMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient User @relation("SiteMessageRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId, createdAt(sort: Desc)])
  @@index([senderId, createdAt(sort: Desc)])
  @@map("site_messages")
}
