generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @default(uuid())
  telegramId        String?  @unique
  username          String   @unique
  email             String?  @unique
  passwordHash      String?
  avatarUrl         String?
  bio               String?  @db.Text
  openClawApiKey    String?
  /// 虾米积分（可兑换 LiteLLM 代理额度等）
  clawPoints        Int      @default(0)
  /// LiteLLM 虚拟 Key；勿写入日志或下发给前端（除专用接口）
  litellmVirtualKey String?
  /// 首次申请 Darwin 时填写的问卷（JSON），申请成功时写入
  darwinOnboarding  Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  rooms           Room[]
  comments        Comment[]
  pointLedger     PointLedger[]
  publishedSkills PublishedSkill[]

  @@index([username])
  @@index([telegramId])
  @@map("users")
}

model PointLedger {
  id              String   @id @default(uuid())
  userId          String
  /// 正数为发放，负数为扣减
  delta           Int
  balanceAfter    Int
  reason          String
  metadata        Json?
  idempotencyKey  String?  @unique
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("point_ledger")
}

/// 用户发布的付费社区技能
model PublishedSkill {
  id                String   @id @default(uuid())
  authorId          String
  title             String
  description       String?  @db.Text
  skillMarkdown     String   @db.Text
  tags              String[]
  /// 每次被调用时向调用方扣除的积分（0 = 免费）
  creditCostPerCall Int      @default(0)
  /// 平台抽成比例 0-1，默认 0.2（20%）
  platformFeeRate   Float    @default(0.2)
  installCount      Int      @default(0)
  /// pending / approved / rejected
  status            String   @default("pending")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([status, createdAt])
  @@map("published_skills")
}

model Room {
  id              String    @id
  hostId          String
  title           String
  description     String?   @db.Text
  lobsterName     String
  isLive          Boolean   @default(false)
  privacyFilters  String[]  @default([])
  dashboardUrl    String?
  viewerCount     Int       @default(0)
  createdAt       DateTime  @default(now())
  startedAt       DateTime?
  endedAt         DateTime?
  
  host            User      @relation(fields: [hostId], references: [id], onDelete: Cascade)
  messages        Message[]
  comments        Comment[]
  agentLogs       AgentLog[]
  screenshots     Screenshot[]

  @@index([hostId])
  @@index([isLive])
  @@index([createdAt])
  @@map("rooms")
}

enum MessageSender {
  user
  agent
  system
}

model Message {
  id          String        @id @default(uuid())
  roomId      String
  sender      MessageSender
  content     String        @db.Text
  metadata    Json?
  timestamp   DateTime      @default(now())
  
  room        Room          @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, timestamp])
  @@map("messages")
}

model Comment {
  id          String    @id @default(uuid())
  roomId      String
  userId      String?
  nickname    String
  content     String    @db.Text
  timestamp   DateTime  @default(now())
  
  room        Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([roomId, timestamp])
  @@map("comments")
}

enum AgentLogStatus {
  pending
  success
  error
}

model AgentLog {
  id          String          @id @default(uuid())
  roomId      String
  action      String
  status      AgentLogStatus  @default(pending)
  details     Json?
  timestamp   DateTime        @default(now())
  
  room        Room            @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, timestamp])
  @@map("agent_logs")
}

model Screenshot {
  id          String    @id @default(uuid())
  roomId      String
  imageUrl    String    @db.Text
  caption     String?
  timestamp   DateTime  @default(now())
  
  room        Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, timestamp])
  @@map("screenshots")
}
