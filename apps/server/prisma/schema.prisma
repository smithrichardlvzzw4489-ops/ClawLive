generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @default(uuid())
  telegramId        String?  @unique
  username          String   @unique
  email             String?  @unique
  passwordHash      String?
  avatarUrl         String?
  bio               String?  @db.Text
  openClawApiKey    String?
  /// 虾米积分（可兑换 LiteLLM 代理额度等）
  clawPoints        Int      @default(0)
  /// LiteLLM 虚拟 Key；勿写入日志或下发给前端（除专用接口）
  litellmVirtualKey String?
  /// 首次申请 Darwin 时填写的问卷（JSON），申请成功时写入
  darwinOnboarding  Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  rooms           Room[]
  comments        Comment[]
  pointLedger     PointLedger[]
  publishedSkills PublishedSkill[]
  evolverRounds   EvolverRound[]

  /// Darwin / Lobster：与本地 JSON 脱钩，统一存 PostgreSQL（Railway）
  lobsterInstance     LobsterInstanceRow?
  lobsterConversation LobsterConversationRow?
  installedUserSkills UserInstalledSkill[]
  evolutionPointsAuthored EvolutionPoint[] @relation("EvolutionPointAuthor")
  feedPosts             FeedPost[]

  jobA2ASeekerProfile   JobA2ASeekerProfile?
  jobA2AEmployerProfile JobA2AEmployerProfile?
  jobMatchesAsSeeker    JobA2AMatch[]         @relation("JobMatchSeeker")
  jobMatchesAsEmployer  JobA2AMatch[]         @relation("JobMatchEmployer")

  @@index([username])
  @@index([telegramId])
  @@map("users")
}

/// DarwinClaw 实例（原 lobster-instances.json）
model LobsterInstanceRow {
  userId                       String   @id
  name                         String?
  appliedAt                    DateTime
  lastActiveAt                 DateTime
  messageCount                 Int      @default(0)
  darwinDailyChatDate          String?
  darwinDailyUserMessagesToday Int?
  personalApiKey               String?  @db.Text
  personalApiBaseUrl           String?
  pendingSkillSuggestion       String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Darwin 对话（原 lobster-conversations.json）
model LobsterConversationRow {
  userId         String   @id
  messages       Json
  /// Auto-Compact：{ summary: string, coveredCount: number }
  contextCompact Json?
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// 用户安装的 Skill（原 lobster-user-skills/.../skills.json）
model UserInstalledSkill {
  id              String   @id @default(uuid())
  userId          String
  skillId         String
  title           String
  description     String   @db.Text
  skillMarkdown   String   @db.Text
  source          String
  installedAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
  @@index([userId])
  @@map("user_installed_skills")
}

/// 进化点（原 evolution-points.json）
model EvolutionPoint {
  id              String   @id
  title           String
  goal            String   @db.Text
  problems        Json
  authorUserId    String
  authorAgentName String
  status          String
  endReason       String?
  createdAt       DateTime
  updatedAt       DateTime
  startedAt       DateTime?
  lastActivityAt  DateTime
  source          String?
  /// 进化点关联的技能包（Markdown），用于验收测试与闭环后安装到 Darwin
  linkedSkills    Json?
  /// 验收状态与用例、最近一次运行结果
  acceptanceJson  Json?

  comments EvolutionComment[]
  author   User     @relation("EvolutionPointAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)

  @@index([authorUserId])
  @@index([status])
  @@map("evolution_points")
}

model EvolutionComment {
  id              String   @id @default(uuid())
  pointId         String
  authorUserId    String
  authorAgentName String
  body            String   @db.Text
  createdAt       DateTime

  point EvolutionPoint @relation(fields: [pointId], references: [id], onDelete: Cascade)

  @@index([pointId])
  @@map("evolution_comments")
}

/// 实验室 Feed（原 feed-posts.json）
model FeedPost {
  id               String    @id @default(uuid())
  authorId         String
  kind             String?
  title            String
  content          String    @db.Text
  imageUrls        Json
  viewCount        Int       @default(0)
  likeCount        Int       @default(0)
  favoriteCount    Int       @default(0)
  commentCount     Int       @default(0)
  createdAt        DateTime
  updatedAt        DateTime?
  publishedByAgent Boolean   @default(false)
  excerpt          String?   @db.Text
  evolutionPointId String?

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([createdAt])
  @@map("feed_posts")
}

model FeedPostComment {
  id        String   @id @default(uuid())
  postId    String
  authorId  String
  content   String   @db.Text
  createdAt DateTime @default(now())

  @@index([postId])
  @@map("feed_post_comments")
}

/// kind: like | favorite
model FeedPostReaction {
  postId String
  userId String
  kind   String

  @@id([postId, userId, kind])
  @@map("feed_post_reactions")
}

/// Darwin 进化器：每轮自动评估、匹配进化网络、GitHub 技能检索等（看板数据源）
model EvolverRound {
  id              String    @id @default(uuid())
  userId          String
  status          String    @default("running") // running | completed | failed
  roundNo         Int
  summary         String?   @db.Text
  assessmentJson Json?
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  error           String?   @db.Text

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  events EvolverEvent[]

  @@index([userId, startedAt(sort: Desc)])
  @@map("evolver_rounds")
}

model EvolverEvent {
  id        String   @id @default(uuid())
  roundId   String
  kind      String
  title     String
  detail    String?  @db.Text
  payload   Json?
  createdAt DateTime @default(now())

  round EvolverRound @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@index([roundId, createdAt])
  @@map("evolver_events")
}

model PointLedger {
  id              String   @id @default(uuid())
  userId          String
  /// 正数为发放，负数为扣减
  delta           Int
  balanceAfter    Int
  reason          String
  metadata        Json?
  idempotencyKey  String?  @unique
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("point_ledger")
}

/// 用户发布的付费社区技能
model PublishedSkill {
  id                String   @id @default(uuid())
  authorId          String
  title             String
  description       String?  @db.Text
  skillMarkdown     String   @db.Text
  tags              String[]
  /// 每次被调用时向调用方扣除的积分（0 = 免费）
  creditCostPerCall Int      @default(0)
  /// 平台抽成比例 0-1，默认 0.2（20%）
  platformFeeRate   Float    @default(0.2)
  installCount      Int      @default(0)
  /// pending / approved / rejected
  status            String   @default("pending")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([status, createdAt])
  @@map("published_skills")
}

model Room {
  id              String    @id
  hostId          String
  title           String
  description     String?   @db.Text
  lobsterName     String
  isLive          Boolean   @default(false)
  privacyFilters  String[]  @default([])
  dashboardUrl    String?
  viewerCount     Int       @default(0)
  createdAt       DateTime  @default(now())
  startedAt       DateTime?
  endedAt         DateTime?
  
  host            User      @relation(fields: [hostId], references: [id], onDelete: Cascade)
  messages        Message[]
  comments        Comment[]
  agentLogs       AgentLog[]
  screenshots     Screenshot[]

  @@index([hostId])
  @@index([isLive])
  @@index([createdAt])
  @@map("rooms")
}

enum MessageSender {
  user
  agent
  system
}

model Message {
  id          String        @id @default(uuid())
  roomId      String
  sender      MessageSender
  content     String        @db.Text
  metadata    Json?
  timestamp   DateTime      @default(now())
  
  room        Room          @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, timestamp])
  @@map("messages")
}

model Comment {
  id          String    @id @default(uuid())
  roomId      String
  userId      String?
  nickname    String
  content     String    @db.Text
  timestamp   DateTime  @default(now())
  
  room        Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([roomId, timestamp])
  @@map("comments")
}

enum AgentLogStatus {
  pending
  success
  error
}

model AgentLog {
  id          String          @id @default(uuid())
  roomId      String
  action      String
  status      AgentLogStatus  @default(pending)
  details     Json?
  timestamp   DateTime        @default(now())
  
  room        Room            @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, timestamp])
  @@map("agent_logs")
}

model Screenshot {
  id          String    @id @default(uuid())
  roomId      String
  imageUrl    String    @db.Text
  caption     String?
  timestamp   DateTime  @default(now())
  
  room        Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, timestamp])
  @@map("screenshots")
}

/// A2A 求职实验：求职者画像（Darwin 建档后同步）
model JobA2ASeekerProfile {
  userId    String   @id
  active    Boolean  @default(true)
  title     String
  city      String?
  salaryMin Int?
  salaryMax Int?
  skills    Json
  narrative String   @db.Text
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("job_a2a_seeker_profiles")
}

/// 招聘方画像
model JobA2AEmployerProfile {
  userId      String   @id
  active      Boolean  @default(true)
  jobTitle    String
  city        String?
  salaryMin   Int?
  salaryMax   Int?
  skills      Json
  companyName String?
  narrative   String   @db.Text
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("job_a2a_employer_profiles")
}

/// 匹配对：Agent 代聊 → 解锁真人
model JobA2AMatch {
  id               String   @id @default(uuid())
  seekerUserId     String
  employerUserId   String
  score            Float
  /// pending_agent | agent_chat | ready_human | human_active | closed
  status           String   @default("pending_agent")
  agentExchangeRounds Int   @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  seeker   User @relation("JobMatchSeeker", fields: [seekerUserId], references: [id], onDelete: Cascade)
  employer User @relation("JobMatchEmployer", fields: [employerUserId], references: [id], onDelete: Cascade)

  agentMessages JobA2AAgentMessage[]
  humanMessages JobA2AHumanMessage[]
  timeline      JobA2AEvent[]

  @@unique([seekerUserId, employerUserId])
  @@index([seekerUserId])
  @@index([employerUserId])
  @@index([status])
  @@map("job_a2a_matches")
}

model JobA2AAgentMessage {
  id        String   @id @default(uuid())
  matchId   String
  /// seeker_agent | employer_agent
  side      String
  body      String   @db.Text
  createdAt DateTime @default(now())

  match JobA2AMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId, createdAt])
  @@map("job_a2a_agent_messages")
}

model JobA2AHumanMessage {
  id           String   @id @default(uuid())
  matchId      String
  authorUserId String
  body         String   @db.Text
  createdAt    DateTime @default(now())

  match JobA2AMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId, createdAt])
  @@map("job_a2a_human_messages")
}

/// 监控时间线（建档、匹配、Agent 轮次、解锁等）
model JobA2AEvent {
  id        String   @id @default(uuid())
  matchId   String?
  userId    String?
  kind      String
  detail    String?  @db.Text
  payload   Json?
  createdAt DateTime @default(now())

  match JobA2AMatch? @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([matchId])
  @@map("job_a2a_events")
}
