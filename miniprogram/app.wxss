page {
  background-color: #f1f5f9;
  color: #0f172a;
  font-size: 28rpx;
  box-sizing: border-box;
}

.btn-primary {
  margin-top: 24rpx;
  padding: 24rpx 48rpx;
  border-radius: 16rpx;
  background: linear-gradient(90deg, #0ea5e9, #8b5cf6);
  color: #fff;
  font-weight: 600;
  text-align: center;
}

.btn-outline {
  margin-top: 16rpx;
  padding: 24rpx 48rpx;
  border-radius: 16rpx;
  border: 2rpx solid #cbd5e1;
  color: #475569;
  text-align: center;
}

.card {
  margin: 32rpx;
  padding: 32rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(15, 23, 42, 0.06);
}

.muted {
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.6;
}
