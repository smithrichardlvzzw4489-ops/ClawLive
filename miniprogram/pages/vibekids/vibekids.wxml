<view class="wrap">
  <view class="card">
    <text class="title">少儿氛围编程</text>
    <text class="muted block">主入口：用一句话生成可预览的小作品。下方将在此页逐步接入原生创作与作品列表。</text>
    <view wx:if="{{!loggedIn}}" class="actions">
      <button class="btn-primary" bindtap="goLogin">微信登录</button>
    </view>
    <view wx:else class="actions">
      <text class="ok">已登录</text>
      <button class="btn-outline" bindtap="tryLoadWorks">拉取我的作品列表</button>
      <button class="btn-outline" bindtap="logout">退出</button>
    </view>
    <text wx:if="{{hint}}" class="muted block hint">{{hint}}</text>
  </view>
</view>
