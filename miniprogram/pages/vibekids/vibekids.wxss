.wrap {
  min-height: 100vh;
  padding-top: 24rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 16rpx;
}

.block {
  display: block;
  margin-top: 16rpx;
}

.actions {
  margin-top: 32rpx;
}

.ok {
  display: block;
  color: #059669;
  font-size: 28rpx;
  margin-bottom: 16rpx;
}

.hint {
  margin-top: 24rpx;
  word-break: break-all;
}

button.btn-primary,
button.btn-outline {
  width: 100%;
  font-size: 28rpx;
}

button.btn-primary::after,
button.btn-outline::after {
  border: none;
}
