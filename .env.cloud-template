# ============================================
# ClawLive 云服务配置模板
# ============================================
# 此配置使用完全免费的云服务，无需本地安装数据库
#
# 使用步骤：
# 1. 复制此文件为 .env
# 2. 按照下面的说明获取云服务凭据
# 3. 替换占位符为实际值
# ============================================

# ------------------------------------------
# PostgreSQL (使用 Supabase - 免费)
# ------------------------------------------
# 获取方式：
# 1. 访问 https://supabase.com/
# 2. 创建免费账号
# 3. 创建新项目
# 4. 在 Settings > Database > Connection String 中找到
# 格式: postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.xxxxxxxxxxxxx.supabase.co:5432/postgres"

# ------------------------------------------
# Redis (使用 Upstash - 免费)
# ------------------------------------------
# 获取方式：
# 1. 访问 https://upstash.com/
# 2. 创建免费账号
# 3. 创建 Redis 数据库
# 4. 复制连接 URL
# 格式: rediss://default:[YOUR-PASSWORD]@[YOUR-ENDPOINT].upstash.io:6379
REDIS_URL="rediss://default:YOUR_PASSWORD@xxxxxx.upstash.io:6379"

# ------------------------------------------
# JWT 密钥 (自定义)
# ------------------------------------------
# 生成方式：
# PowerShell: -join ((65..90) + (97..122) + (48..57) | Get-Random -Count 32 | % {[char]$_})
# 或访问: https://randomkeygen.com/
JWT_SECRET="your-random-secret-min-32-chars"
REFRESH_TOKEN_SECRET="your-another-random-secret-min-32-chars"

# ------------------------------------------
# 服务端口
# ------------------------------------------
PORT=3001
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"

# ------------------------------------------
# Webhook 安全密钥
# ------------------------------------------
WEBHOOK_SECRET="dev-webhook-secret-change-in-production"

# ------------------------------------------
# Telegram (可选)
# ------------------------------------------
# 获取方式：
# 1. 在 Telegram 中搜索 @BotFather
# 2. 发送 /newbot 创建机器人
# 3. 复制 Bot Token
TELEGRAM_BOT_TOKEN=""

# ------------------------------------------
# 前端 URL (生产环境使用)
# ------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ------------------------------------------
# CORS 允许的域名
# ------------------------------------------
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"

# ============================================
# 配置完成后的步骤：
# ============================================
# 1. 保存文件为 .env
# 2. cd apps\server
# 3. pnpm exec prisma migrate deploy
# 4. cd ..\..
# 5. pnpm dev
# ============================================
