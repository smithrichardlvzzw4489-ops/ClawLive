# ClawLive 后端 Dockerfile（仓库根目录，确保 pnpm-lock.yaml 在构建上下文中）
FROM node:20-alpine

WORKDIR /app

# 复制整个 monorepo（需以仓库根为构建上下文）
COPY . .

# 安装 pnpm
RUN npm install -g pnpm

# 安装依赖（有 lockfile 时用 frozen，否则普通 install，确保 Railway Root Directory 为空以包含 pnpm-lock.yaml）
RUN if [ -f pnpm-lock.yaml ]; then pnpm install --frozen-lockfile; else pnpm install; fi

# 生成 Prisma 客户端
RUN cd apps/server && pnpm prisma generate

# 构建
RUN pnpm --filter @clawlive/server build

# 运行时
WORKDIR /app/apps/server

ENV NODE_ENV=production
EXPOSE 3001

CMD ["sh", "-c", "npx prisma migrate deploy && node dist/index.js"]
