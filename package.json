{
  "name": "clawlive",
  "version": "1.0.0",
  "private": true,
  "description": "GITLINK — developer profiles, AI agents, and streaming",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c yellow,cyan \"pnpm --filter @clawlive/server exec tsx src/index.ts\" \"pnpm --filter @clawlive/web exec next dev -p 3000\"",
    "dev:web": "pnpm --filter @clawlive/web exec next dev -p 3000",
    "dev:server": "pnpm --filter @clawlive/server exec tsx src/index.ts",
    "dev:turbo": "turbo run dev --no-color",
    "dev:win": "chcp 65001 >nul & turbo run dev --no-color",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "test": "turbo run test",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "db:migrate": "cd apps/server && pnpm prisma migrate dev",
    "db:studio": "cd apps/server && pnpm prisma studio"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "concurrently": "^9.2.1",
    "turbo": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "pnpm": {
    "overrides": {
      "@types/react": "18.3.28",
      "@types/react-dom": "18.3.7"
    }
  }
}
